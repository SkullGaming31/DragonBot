{
  "compilerOptions": {
    "target": "ES2020",
    "experimentalDecorators": true,
    "module": "CommonJS",
    "moduleResolution": "node",
    "types": [
      "node"
    ],
    "resolveJsonModule": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "removeComments": true,
    "importHelpers": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "environment.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test"
  ]
}